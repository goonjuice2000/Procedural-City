{
    "files.exclude": {
        "node_modules": true,
        ".vscode/": true,
        "utils/": true,
        "runner.js": true,
        "vite.config.js": true,
        "package.json": true,
        "package-lock.json": true,
        ".gitignore": true,
        "global.d.ts": true,
        "jsconfig.json": true,
        "activityChooser.js": true,
        "README.md": true,
        "docs": true
    },
    "editor.quickSuggestions": {
        "comments": "off",
        "strings": "off",
        "other": "off"
    },
    "js/ts.suggest.enabled": false,
    "chat.disableAIFeatures": true
}